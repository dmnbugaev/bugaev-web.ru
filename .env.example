# Email-уведомления о новых заявках через Яндекс.Почту
#
# NUXT_SMTP_USER — ваш Яндекс email (например ivan@yandex.ru)
# NUXT_SMTP_PASS — пароль приложения (НЕ основной пароль!)
#   Получить: id.yandex.ru → Безопасность → Пароли приложений → Создать → Почта
# NUXT_SMTP_TO   — куда приходят заявки (можно тот же email)

NUXT_SMTP_USER=ivan@yandex.ru
NUXT_SMTP_PASS=xxxxxxxxxxxx
NUXT_SMTP_TO=ivan@yandex.ru
